.gitignore
# Build output
/bin/
/obj/
artifacts/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio
.vs/
.vs/**/*

# VS Code settings
.vscode/
.history/

# Rider / JetBrains
.idea/
*.DotSettings.user
*.sln.DotSettings
_ReSharper*/

# Logs
*.log

# ASP.NET secrets
**/secrets.json
**/secrets/*.json

# Docker (nếu dùng Docker)
docker-compose.override.yml
*.env

# OS generated files
.DS_Store
Thumbs.db

# Node/npm/yarn
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test results
TestResults/
*.coverage
*.coveragejson

# Databases
*.db
*.sqlite

# Symbol files
*.pdb

# EF Core
Migrations/

# Publish output
/publish/
/wwwroot/dist/

# HTTP test files
*.http

# Config (environment-specific)
appsettings.Development.json

# Project-specific (TCSoftNails)
TCSoftNails/NailsTcosft3.csproj.user
TCSoftNails/NailsTcosft3.csproj
TCSoftNails/NailsTcosft3.http