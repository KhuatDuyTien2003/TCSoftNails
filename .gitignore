# Angular build output
/dist
/out-tsc

# Node modules
/node_modules

# IDE and editor settings
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project
.vscode/

# Compiled output
*.js
*.js.map

# System files
.DS_Store
Thumbs.db

# Angular cache
.angular/cache

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*.local

# Optional: OS generated files
*.swp
# Ignore everything
/*

!/src/
!/public/

# Keep config files (optional but recommended)
!/.gitignore
!/package.json
!/package-lock.json
!/angular.json
!/tsconfig.json
!/tsconfig.app.json
!/tsconfig.base.json
!/tsconfig.spec.json
!/README.md

# Optional: nếu có thư mục assets/image cần giữ thì thêm:
!/src/assets/
!/src/assets/**